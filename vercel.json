{
    "version": 2,
    "builds": [
      {
        "src": "package.json",
        "use": "@vercel/static-build",
        "config": {
          "distDir": "build"
        }
      },
      {
        "src": "server.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/server.js"
      },
      {
        "src": "/verifyEmail",
        "dest": "/server.js",
        "methods": ["GET"]
      },
      {
        "src": "/(.*)",
        "dest": "/build/$1"
      }
    ],
    "rewrites": [
      { 
        "source": "/(.*)", 
        "destination": "/index.html" 
      }
    ]
  }